<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Mario Bistro Brews — Staff Admin</title>
<meta name="robots" content="noindex, nofollow">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=Josefin+Sans:wght@300;400;600&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#0f0608;--bg2:#160b0d;--bg3:#1c0e10;
  --gold:#c9a84c;--goldd:#8a6e2a;
  --cream:#e8d5a3;--muted:#7a5c40;
  --border:#2e1810;--border2:#3d2010;
  --green:#2a6a2a;--radius:6px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--cream);font-family:'Josefin Sans',sans-serif;font-size:14px;min-height:100vh}
#login-screen{display:flex;align-items:center;justify-content:center;min-height:100vh;padding:24px}
.login-box{background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:40px 32px;width:100%;max-width:340px;text-align:center}
.login-logo{font-family:'Cormorant Garamond',serif;font-size:22px;color:var(--gold);letter-spacing:4px;text-transform:uppercase;margin-bottom:4px}
.login-sub{font-size:10px;letter-spacing:2px;color:var(--muted);text-transform:uppercase;margin-bottom:32px}
.pin-dots{display:flex;justify-content:center;gap:14px;margin-bottom:28px}
.pin-dot{width:14px;height:14px;border-radius:50%;background:var(--border);border:1px solid var(--goldd);transition:background .15s}
.pin-dot.filled{background:var(--gold)}
.pin-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
.pin-btn{background:var(--bg3);border:1px solid var(--border);color:var(--cream);font-family:'Josefin Sans',sans-serif;font-size:18px;font-weight:300;padding:16px;border-radius:var(--radius);cursor:pointer;transition:background .15s}
.pin-btn:active{background:var(--goldd)}
.pin-error{color:#c06060;font-size:11px;letter-spacing:1px;margin-top:12px;min-height:16px}
#app{display:none;flex-direction:column;min-height:100vh}
.topbar{background:var(--bg2);border-bottom:1px solid var(--border);padding:0 16px;height:52px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50}
.topbar-logo{font-family:'Cormorant Garamond',serif;font-size:16px;color:var(--gold);letter-spacing:3px;text-transform:uppercase}
.logout-btn{font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);cursor:pointer;background:none;border:none;font-family:'Josefin Sans',sans-serif}
.menu-switcher{background:var(--bg2);border-bottom:1px solid var(--border);display:flex;padding:0 16px;gap:0}
.msw-tab{padding:0 20px;height:38px;display:flex;align-items:center;font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);cursor:pointer;border-bottom:2px solid transparent;transition:color .15s}
.msw-tab.active{color:var(--gold);border-bottom-color:var(--gold)}
.bottom-nav{background:var(--bg2);border-top:1px solid var(--border);display:flex;position:sticky;bottom:0;z-index:50;overflow-x:auto;scrollbar-width:none}
.bottom-nav::-webkit-scrollbar{display:none}
.bnav-tab{flex-shrink:0;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:8px 12px;gap:3px;cursor:pointer;border:none;background:none;color:var(--muted);font-family:'Josefin Sans',sans-serif;font-size:8px;letter-spacing:1px;text-transform:uppercase;border-top:2px solid transparent;transition:color .15s}
.bnav-tab svg{width:18px;height:18px;stroke:currentColor;fill:none;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round}
.bnav-tab.active{color:var(--gold);border-top-color:var(--gold)}
.main{flex:1;padding:16px;padding-bottom:80px;max-width:680px;margin:0 auto;width:100%}
.sec-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
.sec-title{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:400;color:var(--cream)}
.btn-add{background:var(--gold);color:var(--bg);border:none;padding:8px 16px;font-family:'Josefin Sans',sans-serif;font-size:10px;letter-spacing:1.5px;text-transform:uppercase;font-weight:600;cursor:pointer;border-radius:var(--radius);display:flex;align-items:center;gap:6px}
.stats-bar{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border);border-radius:var(--radius);overflow:hidden;margin-bottom:16px}
.stat{background:var(--bg2);padding:12px;text-align:center}
.stat-num{font-family:'Cormorant Garamond',serif;font-size:24px;color:var(--gold)}
.stat-label{font-size:9px;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);margin-top:2px}
.item-list{display:flex;flex-direction:column;gap:1px;background:var(--border);border-radius:var(--radius);overflow:hidden}
.item-card{background:var(--bg2);padding:14px 16px;display:flex;align-items:flex-start;gap:12px;transition:background .15s}
.item-card:hover{background:var(--bg3)}
.item-card.unavailable{opacity:.4}
.item-main{flex:1;min-width:0;cursor:pointer}
.item-name{font-family:'Cormorant Garamond',serif;font-size:17px;color:var(--cream);margin-bottom:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.item-desc{font-size:11px;color:var(--muted);line-height:1.5;margin-bottom:6px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.item-meta{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.item-price{font-size:14px;color:var(--gold)}
.badge{font-size:9px;letter-spacing:1px;text-transform:uppercase;padding:2px 7px;border-radius:2px}
.badge-special{background:#2a1800;color:var(--gold);border:1px solid var(--goldd)}
.badge-off{background:#2a0a0a;color:#c06060;border:1px solid #4a1a1a}
.badge-tag{background:#0a1a0a;color:#7ab87a;border:1px solid #1a3a1a}
.item-actions{display:flex;flex-direction:column;gap:6px;flex-shrink:0}
.icon-btn{width:32px;height:32px;border-radius:var(--radius);border:1px solid var(--border);background:var(--bg);cursor:pointer;display:flex;align-items:center;justify-content:center}
.icon-btn svg{width:15px;height:15px;stroke:var(--muted);fill:none;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round}
.icon-btn.active svg{stroke:var(--gold)}
.icon-btn.danger:hover{background:#2a0808}
.icon-btn.danger:hover svg{stroke:#c06060}
.modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:200;align-items:flex-end;justify-content:center}
.modal-bg.open{display:flex}
.modal{background:var(--bg2);border:1px solid var(--border);border-radius:12px 12px 0 0;width:100%;max-width:520px;max-height:92vh;overflow-y:auto;padding:24px 20px 40px}
.modal-handle{width:36px;height:3px;background:var(--border);border-radius:2px;margin:0 auto 20px}
.modal-title{font-family:'Cormorant Garamond',serif;font-size:20px;color:var(--cream);margin-bottom:20px}
.form-row{margin-bottom:14px}
.form-label{font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);display:block;margin-bottom:5px}
.form-input,.form-select,.form-textarea{width:100%;background:var(--bg);border:1px solid var(--border);color:var(--cream);padding:10px 12px;font-family:'Josefin Sans',sans-serif;font-size:13px;border-radius:var(--radius)}
.form-input:focus,.form-select:focus,.form-textarea:focus{outline:none;border-color:var(--goldd)}
.form-textarea{height:80px;resize:none}
.form-select option{background:var(--bg2)}
.form-row-2{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px}
.form-toggles{display:flex;gap:12px;margin-bottom:14px}
.toggle-label{display:flex;align-items:center;gap:8px;cursor:pointer;font-size:11px;letter-spacing:1px;text-transform:uppercase;color:var(--muted)}
.toggle-input{display:none}
.toggle-track{width:36px;height:20px;background:var(--border);border-radius:10px;position:relative;transition:background .2s;flex-shrink:0}
.toggle-track::after{content:'';position:absolute;top:2px;left:2px;width:16px;height:16px;background:#555;border-radius:50%;transition:transform .2s,background .2s}
.toggle-input:checked+.toggle-track{background:var(--goldd)}
.toggle-input:checked+.toggle-track::after{transform:translateX(16px);background:var(--gold)}
.modal-btns{display:flex;gap:10px;margin-top:20px}
.btn-save{flex:1;background:var(--gold);color:var(--bg);border:none;padding:12px;font-family:'Josefin Sans',sans-serif;font-size:11px;letter-spacing:1.5px;text-transform:uppercase;font-weight:600;cursor:pointer;border-radius:var(--radius)}
.btn-cancel{padding:12px 20px;background:transparent;color:var(--muted);border:1px solid var(--border);font-family:'Josefin Sans',sans-serif;font-size:11px;cursor:pointer;border-radius:var(--radius)}
.btn-delete{padding:12px 16px;background:transparent;color:#c06060;border:1px solid #4a1a1a;font-family:'Josefin Sans',sans-serif;font-size:11px;cursor:pointer;border-radius:var(--radius)}
.settings-save{background:var(--gold);color:var(--bg);border:none;padding:12px 24px;font-family:'Josefin Sans',sans-serif;font-size:11px;letter-spacing:1.5px;text-transform:uppercase;font-weight:600;cursor:pointer;border-radius:var(--radius);margin-top:8px;width:100%}
.toast{position:fixed;bottom:90px;left:50%;transform:translateX(-50%) translateY(20px);background:var(--bg2);border:1px solid var(--border);color:var(--cream);padding:10px 20px;border-radius:var(--radius);font-size:12px;opacity:0;transition:all .25s;z-index:300;white-space:nowrap;pointer-events:none}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
.toast.success{border-color:var(--goldd);color:var(--gold)}
.toast.error{border-color:#4a1a1a;color:#c06060}
.empty{text-align:center;padding:48px 24px;color:var(--muted)}
.loading{text-align:center;padding:40px;color:var(--muted);font-size:11px;letter-spacing:2px;text-transform:uppercase}
</style>
</head>
<body>

<!-- LOGIN -->
<div id="login-screen">
  <div class="login-box">
    <div class="login-logo">Mario Bistro</div>
    <div class="login-sub">Staff access · Enter PIN</div>
    <div class="pin-dots">
      <div class="pin-dot" id="d0"></div><div class="pin-dot" id="d1"></div>
      <div class="pin-dot" id="d2"></div><div class="pin-dot" id="d3"></div>
    </div>
    <div class="pin-grid">
      <button class="pin-btn" onclick="pinPress('1')">1</button>
      <button class="pin-btn" onclick="pinPress('2')">2</button>
      <button class="pin-btn" onclick="pinPress('3')">3</button>
      <button class="pin-btn" onclick="pinPress('4')">4</button>
      <button class="pin-btn" onclick="pinPress('5')">5</button>
      <button class="pin-btn" onclick="pinPress('6')">6</button>
      <button class="pin-btn" onclick="pinPress('7')">7</button>
      <button class="pin-btn" onclick="pinPress('8')">8</button>
      <button class="pin-btn" onclick="pinPress('9')">9</button>
      <button class="pin-btn" onclick="pinClear()">✕</button>
      <button class="pin-btn" onclick="pinPress('0')">0</button>
      <button class="pin-btn" onclick="pinBack()">⌫</button>
    </div>
    <div class="pin-error" id="pin-error"></div>
  </div>
</div>

<!-- APP -->
<div id="app">
  <div class="topbar">
    <div class="topbar-logo">MB Brews Admin</div>
    <button class="logout-btn" onclick="logout()">Sign out</button>
  </div>
  <div class="menu-switcher">
    <div class="msw-tab active" id="msw-bar" onclick="switchMenu('bar')">🍷 Bar menu</div>
    <div class="msw-tab" id="msw-dinner" onclick="switchMenu('dinner')">🍕 Dinner menu</div>
    <div class="msw-tab" id="msw-settings" onclick="switchMenu('settings')">⚙ Settings</div>
    <div class="msw-tab" id="msw-vendors" onclick="switchMenu('vendors')">🤝 Vendors</div>
  </div>
  <div class="main" id="main-content">
    <div class="loading">Loading...</div>
  </div>
  <!-- BAR NAV -->
  <nav class="bottom-nav" id="bar-nav">
    <button class="bnav-tab active" onclick="showSection('special')" id="tab-special">
      <svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>Specials
    </button>
    <button class="bnav-tab" onclick="showSection('wine')" id="tab-wine">
      <svg viewBox="0 0 24 24"><path d="M8 22h8M12 11v11M5 3h14l-2 8a5 5 0 0 1-10 0L5 3z"/></svg>Wine
    </button>
    <button class="bnav-tab" onclick="showSection('beer')" id="tab-beer">
      <svg viewBox="0 0 24 24"><path d="M17 11h1a3 3 0 0 1 0 6h-1M5 11h12v10a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V11zM9 3v8M15 3v8M5 7h14"/></svg>Beer
    </button>
    <button class="bnav-tab" onclick="showSection('cocktail')" id="tab-cocktail">
      <svg viewBox="0 0 24 24"><path d="M8 22h8M12 17V3M3 3h18l-9 9-9-9z"/></svg>Bar
    </button>
    <button class="bnav-tab" onclick="showSection('food')" id="tab-food">
      <svg viewBox="0 0 24 24"><path d="M3 11l19-9-9 19-2-8-8-2z"/></svg>Food
    </button>
    <button class="bnav-tab" onclick="showSection('na')" id="tab-na">
      <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>N/A
    </button>
  </nav>
  <!-- DINNER NAV -->
  <nav class="bottom-nav" id="dinner-nav" style="display:none">
    <button class="bnav-tab active" onclick="showSection('dinner_special')" id="tab-dinner_special">
      <svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>Specials
    </button>
    <button class="bnav-tab" onclick="showSection('pizza')" id="tab-pizza">
      <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>Pizza
    </button>
    <button class="bnav-tab" onclick="showSection('panini')" id="tab-panini">
      <svg viewBox="0 0 24 24"><path d="M3 11l19-9-9 19-2-8-8-2z"/></svg>Paninis
    </button>
    <button class="bnav-tab" onclick="showSection('small_plate')" id="tab-small_plate">
      <svg viewBox="0 0 24 24"><path d="M18 8h1a4 4 0 0 1 0 8h-1M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8zM6 1v3M10 1v3M14 1v3"/></svg>Plates
    </button>
    <button class="bnav-tab" onclick="showSection('pasta')" id="tab-pasta">
      <svg viewBox="0 0 24 24"><path d="M3 6h18M3 12h18M3 18h18"/></svg>Pasta
    </button>
    <button class="bnav-tab" onclick="showSection('brunch')" id="tab-brunch">
      <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>Brunch
    </button>
    <button class="bnav-tab" onclick="showSection('soup_salad')" id="tab-soup_salad">
      <svg viewBox="0 0 24 24"><path d="M12 2a10 10 0 0 1 10 10H2A10 10 0 0 1 12 2zM7 22h10M12 16v6"/></svg>Soups
    </button>
  </nav>
</div>

<!-- ITEM MODAL -->
<div class="modal-bg" id="item-modal">
  <div class="modal">
    <div class="modal-handle"></div>
    <div class="modal-title" id="modal-title">Add item</div>
    <div class="form-row">
      <label class="form-label">Item name</label>
      <input class="form-input" id="f-name" placeholder="e.g. Bistro Negroni">
    </div>
    <div class="form-row">
      <label class="form-label">Description</label>
      <textarea class="form-textarea" id="f-desc" placeholder="Ingredients, tasting notes..."></textarea>
    </div>
    <div class="form-row-2">
      <div>
        <label class="form-label">Price</label>
        <input class="form-input" id="f-price" type="number" step="0.50" placeholder="0.00">
      </div>
      <div>
        <label class="form-label">Category</label>
        <select class="form-select" id="f-category" onchange="toggleWineType(this.value)">
          <optgroup label="Bar menu">
            <option value="wine">Wine</option>
            <option value="beer">Beer</option>
            <option value="cocktail">Cocktail</option>
            <option value="spirit">Spirit</option>
            <option value="na">N/A Drink</option>
            <option value="special">Bar Special</option>
          </optgroup>
          <optgroup label="Dinner menu">
            <option value="pizza">Pizza</option>
            <option value="panini">Panini</option>
            <option value="small_plate">Small Plate</option>
            <option value="pasta">Pasta</option>
            <option value="soup_salad">Soup & Salad</option>
            <option value="dinner_special">Dinner Special</option>
            <option value="brunch">Brunch</option>
            <option value="beverage">Beverage</option>
          </optgroup>
        </select>
      </div>
    </div>
    <div class="form-row" id="wine-type-row" style="display:none">
      <label class="form-label">Wine type</label>
      <select class="form-select" id="f-wine-type">
        <option value="red">Red</option>
        <option value="white">White</option>
        <option value="rose">Rosé</option>
        <option value="sparkling">Sparkling</option>
        <option value="other">Other</option>
      </select>
    </div>
    <div class="form-row" id="vendor-row">
      <label class="form-label">Vendor (optional)</label>
      <select class="form-select" id="f-vendor">
        <option value="">— None —</option>
      </select>
    </div>
    <div class="form-row">
      <label class="form-label">Badge (optional)</label>
      <input class="form-input" id="f-badge" placeholder="e.g. GF · Local · Veg · Tonight only">
    </div>
    <div class="form-toggles">
      <label class="toggle-label">
        <input type="checkbox" class="toggle-input" id="f-available" checked>
        <div class="toggle-track"></div>Available
      </label>
      <label class="toggle-label">
        <input type="checkbox" class="toggle-input" id="f-special">
        <div class="toggle-track"></div>Tonight's special
      </label>
    </div>
    <div class="modal-btns">
      <button class="btn-cancel" onclick="closeModal()">Cancel</button>
      <button class="btn-delete" id="btn-delete" style="display:none" onclick="deleteItem()">Delete</button>
      <button class="btn-save" onclick="saveItem()">Save item</button>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
const API = '';
let currentSection = 'special';
let currentMenu = 'bar';
let editingId = null;

const SECTION_LABELS = {
  special:'Bar Specials', wine:'Wine', beer:'Beer & Draft',
  cocktail:'Cocktails & Spirits', food:'Food', na:'N/A Drinks',
  pizza:'Pizza', panini:'Paninis & Sandwiches', small_plate:'Small Plates',
  pasta:'Pasta', soup_salad:'Soups & Salads', dinner_special:'Dinner Specials',
  brunch:'Brunch & Morning', beverage:'Beverages', settings:'Settings'
};

// ── PIN ───────────────────────────────────────────────────────────
let pinVal = '';
function pinPress(d){if(pinVal.length>=4)return;pinVal+=d;updateDots();if(pinVal.length===4)submitPin();}
function pinBack(){pinVal=pinVal.slice(0,-1);updateDots();}
function pinClear(){pinVal='';updateDots();}
function updateDots(){for(let i=0;i<4;i++)document.getElementById('d'+i).classList.toggle('filled',i<pinVal.length);}
async function submitPin(){
  try{
    const r=await fetch(API+'/api/auth/login',{method:'POST',credentials:'include',headers:{'Content-Type':'application/json'},body:JSON.stringify({pin:pinVal})});
    if(r.ok){document.getElementById('login-screen').style.display='none';document.getElementById('app').style.display='flex';switchMenu('bar');}
    else{document.getElementById('pin-error').textContent='Incorrect PIN — try again';pinVal='';updateDots();setTimeout(()=>document.getElementById('pin-error').textContent='',2000);}
  }catch(e){document.getElementById('pin-error').textContent='Connection error';pinVal='';updateDots();}
}
async function logout(){await fetch(API+'/api/auth/logout',{method:'POST',credentials:'include'});document.getElementById('app').style.display='none';document.getElementById('login-screen').style.display='flex';pinVal='';updateDots();}

window.addEventListener('DOMContentLoaded',async()=>{
  try{const r=await fetch(API+'/api/auth/check',{credentials:'include'});const d=await r.json();
    if(d.authed){document.getElementById('login-screen').style.display='none';document.getElementById('app').style.display='flex';switchMenu('bar');}
  }catch(e){}
});

// ── MENU SWITCHER ─────────────────────────────────────────────────
function switchMenu(menu){
  currentMenu = menu;
  document.querySelectorAll('.msw-tab').forEach(t=>t.classList.remove('active'));
  document.getElementById('msw-'+menu)?.classList.add('active');
  const barNav    = document.getElementById('bar-nav');
  const dinnerNav = document.getElementById('dinner-nav');
  if(menu === 'bar'){
    barNav.style.display='flex'; dinnerNav.style.display='none';
    showSection('special');
  } else if(menu === 'dinner'){
    barNav.style.display='none'; dinnerNav.style.display='flex';
    showSection('dinner_special');
  } else if(menu === 'vendors'){
    barNav.style.display='none'; dinnerNav.style.display='none';
    document.getElementById('main-content').innerHTML = '<div id="vendors-list"><div class="loading">Loading...</div></div><button onclick="openVendorModal(null)" style="margin:16px auto;display:block;background:var(--gold);color:var(--bg);border:none;padding:12px 24px;font-family:Josefin Sans,sans-serif;font-size:11px;letter-spacing:1.5px;cursor:pointer;border-radius:4px">+ Add Vendor</button>';
    loadVendors();
  } else if(menu === 'settings'){
    barNav.style.display='none'; dinnerNav.style.display='none';
    renderSettings();
  }
}

// ── SECTIONS ─────────────────────────────────────────────────────
async function showSection(sec){
  currentSection = sec;
  document.querySelectorAll('.bnav-tab').forEach(t=>t.classList.remove('active'));
  const tab = document.getElementById('tab-'+sec);
  if(tab) tab.classList.add('active');
  renderSection(sec);
}

async function fetchItems(sec){
  if(sec === 'special'){
    const r = await fetch(API+'/api/admin/items',{credentials:'include'});
    const items = await r.json();
    return items.filter(i=>i.is_special);
  }
  if(sec === 'cocktail'){
    const [r1,r2] = await Promise.all([
      fetch(API+'/api/admin/items?category=cocktail',{credentials:'include'}),
      fetch(API+'/api/admin/items?category=spirit',{credentials:'include'})
    ]);
    return [...await r1.json(),...await r2.json()];
  }
  const r = await fetch(API+`/api/admin/items?category=${sec}`,{credentials:'include'});
  return r.json();
}

async function renderSection(sec){
  const main = document.getElementById('main-content');
  main.innerHTML = '<div class="loading">Loading...</div>';
  try{
    const items = await fetchItems(sec);
    const avail = items.filter(i=>i.available).length;
    const off   = items.filter(i=>!i.available).length;
    const defaultCat = sec==='special'?'special':sec==='cocktail'?'cocktail':sec;
    let html = `
      <div class="sec-header">
        <div class="sec-title">${SECTION_LABELS[sec]||sec}</div>
        <button class="btn-add" onclick="openModal(null,'${defaultCat}')">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>Add
        </button>
      </div>
      <div class="stats-bar">
        <div class="stat"><div class="stat-num">${items.length}</div><div class="stat-label">Total</div></div>
        <div class="stat"><div class="stat-num">${avail}</div><div class="stat-label">Available</div></div>
        <div class="stat"><div class="stat-num">${off}</div><div class="stat-label">86'd</div></div>
      </div>`;
    if(!items.length){
      html += `<div class="empty"><p style="font-size:32px;opacity:.2;margin-bottom:12px">◇</p><p>No items yet — tap Add</p></div>`;
    } else {
      html += '<div class="item-list">';
      items.forEach(item=>{
        const price = item.price ? `$${parseFloat(item.price).toFixed(2)}` : 'MP';
        const badges = [];
        if(item.is_special) badges.push(`<span class="badge badge-special">★ Special</span>`);
        if(!item.available) badges.push(`<span class="badge badge-off">86'd</span>`);
        if(item.badge)      badges.push(`<span class="badge badge-tag">${item.badge}</span>`);
        html += `
          <div class="item-card ${!item.available?'unavailable':''}" id="card-${item.id}">
            <div class="item-main" onclick="openModal('${item.id}')">
              <div class="item-name">${item.name}</div>
              <div class="item-desc">${item.description||''}</div>
              <div class="item-meta"><span class="item-price">${price}</span>${badges.join('')}</div>
            </div>
            <div class="item-actions">
              <button class="icon-btn ${item.is_special?'active':''}" title="Toggle special" onclick="toggleSpecial('${item.id}',this)">
                <svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              </button>
              <button class="icon-btn ${!item.available?'active':''}" title="${item.available?'86 item':'Restore'}" onclick="toggleAvailable('${item.id}',this)">
                <svg viewBox="0 0 24 24">${item.available
                  ?'<path d="M1 1l22 22M16.72 11.06A10.94 10.94 0 0 1 19 12.55M5 12.55a10.94 10.94 0 0 1 5.17-2.39M10.71 5.05A16 16 0 0 1 22.56 9M1.42 9a15.91 15.91 0 0 1 4.7-2.88M15 12a3 3 0 1 1-3-3"/>'
                  :'<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>'
                }</svg>
              </button>
              <button class="icon-btn danger" onclick="openModal('${item.id}')">
                <svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
              </button>
            </div>
          </div>`;
      });
      html += '</div>';
    }
    main.innerHTML = html;
  }catch(e){main.innerHTML=`<div class="empty"><p>Error: ${e.message}</p></div>`;}
}

// ── TOGGLES ───────────────────────────────────────────────────────
async function toggleAvailable(id,btn){
  try{
    const r=await fetch(API+`/api/admin/items/${id}/toggle`,{method:'PATCH',credentials:'include'});
    const d=await r.json();
    document.getElementById('card-'+id)?.classList.toggle('unavailable',!d.available);
    showToast(d.available?'Item restored ✓':'Item 86\'d','success');
    setTimeout(()=>renderSection(currentSection),400);
  }catch(e){showToast('Error: '+e.message,'error');}
}

async function toggleSpecial(id,btn){
  try{
    const r=await fetch(API+`/api/admin/items/${id}/special`,{method:'PATCH',credentials:'include'});
    const d=await r.json();
    btn.classList.toggle('active',d.is_special);
    showToast(d.is_special?'★ Marked as special':'Removed from specials','success');
    setTimeout(()=>renderSection(currentSection),400);
  }catch(e){showToast('Error: '+e.message,'error');}
}

// ── WINE TYPE TOGGLE ──────────────────────────────────────────────
function toggleWineType(cat) {
  const row = document.getElementById('wine-type-row');
  row.style.display = cat === 'wine' ? 'block' : 'none';
}

// ── MODAL ─────────────────────────────────────────────────────────
async function openModal(id,defaultCat){
  editingId=id;
  document.getElementById('modal-title').textContent=id?'Edit item':'Add item';
  document.getElementById('btn-delete').style.display=id?'block':'none';
  if(id){
    try{
      const r=await fetch(API+`/api/admin/items/${id}`,{credentials:'include'});
      const item=await r.json();
      document.getElementById('f-name').value=item.name||'';
      document.getElementById('f-desc').value=item.description||'';
      document.getElementById('f-price').value=item.price||'';
      document.getElementById('f-badge').value=item.badge||'';
      document.getElementById('f-category').value=item.category||'cocktail';
      document.getElementById('f-wine-type').value=item.wine_type||'red';
document.getElementById('f-vendor').value=item.vendor_id||'';      
document.getElementById('f-vendor').value=item.vendor_id||'';
      document.getElementById('f-available').checked=item.available;
      document.getElementById('f-special').checked=item.is_special;
      toggleWineType(item.category);
    }catch(e){showToast('Error loading item','error');return;}
  } else {
    document.getElementById('f-name').value='';
    document.getElementById('f-desc').value='';
    document.getElementById('f-price').value='';
    document.getElementById('f-badge').value='';
    const cat = defaultCat||currentSection||'cocktail';
    document.getElementById('f-category').value=cat;
    document.getElementById('f-wine-type').value='red';
    document.getElementById('f-vendor').value='';
    document.getElementById('f-available').checked=true;
    document.getElementById('f-special').checked=false;
    toggleWineType(cat);
  }
  loadVendorDropdown();
  document.getElementById('item-modal').classList.add('open');
}

function closeModal(){document.getElementById('item-modal').classList.remove('open');editingId=null;}

async function saveItem(){
  const body={
    name:document.getElementById('f-name').value.trim(),
    description:document.getElementById('f-desc').value.trim(),
    price:parseFloat(document.getElementById('f-price').value)||null,
    badge:document.getElementById('f-badge').value.trim()||null,
    vendor_id:document.getElementById('f-vendor').value ? parseInt(document.getElementById('f-vendor').value) : null,
    wine_type:document.getElementById('f-wine-type').value||null,
    category:document.getElementById('f-category').value,
    available:document.getElementById('f-available').checked,
    is_special:document.getElementById('f-special').checked,
  };
  if(!body.name){showToast('Name is required','error');return;}
  try{
    if(editingId){
      await fetch(API+`/api/admin/items/${editingId}`,{method:'PATCH',credentials:'include',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
      showToast('Item updated ✓','success');
    } else {
      await fetch(API+'/api/admin/items',{method:'POST',credentials:'include',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
      showToast('Item added ✓','success');
    }
    closeModal();renderSection(currentSection);
  }catch(e){showToast('Error: '+e.message,'error');}
}

async function deleteItem(){
  if(!editingId)return;
  if(!confirm('Delete this item? Cannot be undone.'))return;
  try{
    await fetch(API+`/api/admin/items/${editingId}`,{method:'DELETE',credentials:'include'});
    showToast('Deleted','success');closeModal();renderSection(currentSection);
  }catch(e){showToast('Error: '+e.message,'error');}
}

// ── SETTINGS ─────────────────────────────────────────────────────
async function renderSettings(){
  const main=document.getElementById('main-content');
  main.innerHTML='<div class="loading">Loading...</div>';
  try{
    const r=await fetch(API+'/api/settings');
    const s=await r.json();
    main.innerHTML=`
      <div class="sec-header"><div class="sec-title">Settings</div></div>
      <div style="display:flex;flex-direction:column;gap:14px">
        <div class="form-row"><label class="form-label">Hours</label><input class="form-input" id="s-hours" value="${s.hours||''}"></div>
        <div class="form-row"><label class="form-label">Kitchen hours</label><input class="form-input" id="s-kitchen" value="${s.kitchen_hours||''}"></div>
        <div class="form-row"><label class="form-label">Phone</label><input class="form-input" id="s-phone" value="${s.phone||''}"></div>
        <div class="form-row"><label class="form-label">Email</label><input class="form-input" id="s-email" value="${s.email||''}"></div>
        <div class="form-row"><label class="form-label">Address</label><input class="form-input" id="s-address" value="${s.address||''}"></div>
        <div class="form-row"><label class="form-label">Specials banner</label><input class="form-input" id="s-banner" value="${s.specials_banner||''}"></div>
        <button class="settings-save" onclick="saveSettings()">Save settings</button>
        <div style="margin-top:16px;padding-top:16px;border-top:1px solid var(--border)">
          <div class="form-label" style="margin-bottom:8px">Change staff PIN</div>
          <input class="form-input" id="s-pin" type="password" placeholder="New 4-digit PIN" maxlength="4" style="margin-bottom:8px">
          <button class="settings-save" style="background:var(--bg3);color:var(--cream);border:1px solid var(--border)" onclick="savePin()">Update PIN</button>
        </div>
      </div>`;
  }catch(e){main.innerHTML='<div class="empty"><p>Error loading settings</p></div>';}
}

async function saveSettings(){
  const body={
    hours:document.getElementById('s-hours').value,
    kitchen_hours:document.getElementById('s-kitchen').value,
    phone:document.getElementById('s-phone').value,
    email:document.getElementById('s-email').value,
    address:document.getElementById('s-address').value,
    specials_banner:document.getElementById('s-banner').value,
  };
  try{
    await fetch(API+'/api/admin/settings',{method:'PATCH',credentials:'include',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
    showToast('Settings saved ✓','success');
  }catch(e){showToast('Error: '+e.message,'error');}
}

async function savePin(){
  const pin=document.getElementById('s-pin').value;
  if(pin.length!==4||isNaN(pin)){showToast('PIN must be 4 digits','error');return;}
  try{
    await fetch(API+'/api/admin/settings',{method:'PATCH',credentials:'include',headers:{'Content-Type':'application/json'},body:JSON.stringify({admin_pin:pin})});
    showToast('PIN updated ✓','success');document.getElementById('s-pin').value='';
  }catch(e){showToast('Error: '+e.message,'error');}
}

// ── TOAST ─────────────────────────────────────────────────────────
let toastTimer;
function showToast(msg,type='success'){
  const t=document.getElementById('toast');
  t.textContent=msg;t.className=`toast ${type} show`;
  clearTimeout(toastTimer);toastTimer=setTimeout(()=>t.classList.remove('show'),2800);
}

document.getElementById('item-modal').addEventListener('click',function(e){if(e.target===this)closeModal();});

// ── VENDORS ──────────────────────────────────────────────────────
var editingVendorId = null;

}
async function loadVendorDropdown(selectedId) {
  try {
    const res = await fetch('/api/vendors');
    const vendors = await res.json();
    const sel = document.getElementById('f-vendor');
    sel.innerHTML = '<option value="">— None —</option>';
    vendors.forEach(v => {
      const o = document.createElement('option');
      o.value = v.id;
      o.textContent = v.name;
      sel.appendChild(o);
    });
    if(selectedId) sel.value = selectedId;
  } catch(e) { console.error(e); }
}




async function loadVendors() {
  try {
    const res = await fetch('/api/vendors');
    const vendors = await res.json();
    const el = document.getElementById('vendors-list');
    if (!vendors.length) { el.innerHTML = '<div class="empty"><p>No vendors yet</p></div>'; return; }
    el.innerHTML = vendors.map(v =>
      '<div style="background:#1a0e10;border:1px solid #2a1a10;border-radius:6px;padding:16px;margin-bottom:10px">' +
        '<div style="display:flex;justify-content:space-between;align-items:flex-start">' +
          '<div>' +
            '<div style="font-size:16px;color:#d4af7a;margin-bottom:4px">' + v.name + (v.featured ? ' <span style="font-size:10px;background:#8b7355;color:#0a0604;padding:2px 6px;border-radius:10px">Featured</span>' : '') + '</div>' +
            '<div style="font-size:11px;color:#6a5a4a;margin-bottom:4px">' + (v.tagline||'') + '</div>' +
            '<div style="font-size:11px;color:#8a7a6a">' + (v.what_they_supply||'') + '</div>' +
            (v.website_url ? '<a href="' + v.website_url + '" target="_blank" style="font-size:10px;color:#8b7355">' + v.website_url + '</a>' : '') +
          '</div>' +
          '<div style="display:flex;gap:6px">' +
            '<button onclick="editVendor(' + v.id + ')" style="background:transparent;border:1px solid #2a1a10;color:#8a7a6a;padding:5px 10px;cursor:pointer;border-radius:4px;font-size:11px">Edit</button>' +
            '<button onclick="deleteVendor(' + v.id + ',\'' + v.name + '\')" style="background:transparent;border:1px solid #4a1a1a;color:#c06060;padding:5px 10px;cursor:pointer;border-radius:4px;font-size:11px">Delete</button>' +
          '</div>' +
        '</div>' +
      '</div>'
    ).join('');
  } catch(e) { console.error(e); }
}

function openVendorModal(vendor) {
  editingVendorId = vendor ? vendor.id : null;
  document.getElementById('v-modal-title').textContent = vendor ? 'Edit Vendor' : 'Add Vendor';
  document.getElementById('v-name').value = vendor ? vendor.name||'' : '';
  document.getElementById('v-tagline').value = vendor ? vendor.tagline||'' : '';
  document.getElementById('v-supply').value = vendor ? vendor.what_they_supply||'' : '';
  document.getElementById('v-story').value = vendor ? vendor.story||'' : '';
  document.getElementById('v-website').value = vendor ? vendor.website_url||'' : '';
  document.getElementById('v-logo').value = vendor ? vendor.logo_url||'' : '';
  document.getElementById('v-country').value = vendor ? vendor.country||'' : '';
  document.getElementById('v-category').value = vendor ? vendor.category||'other' : 'other';
  document.getElementById('v-featured').checked = vendor ? !!vendor.featured : false;
  document.getElementById('vendor-modal').style.display = 'block';
}

function closeVendorModal() {
  document.getElementById('vendor-modal').style.display = 'none';
  editingVendorId = null;
}

async function saveVendor() {
  const name = document.getElementById('v-name').value.trim();
  if (!name) { alert('Name is required'); return; }
  const data = {
    name, slug: name.toLowerCase().replace(/[^a-z0-9]+/g,'-'),
    tagline: document.getElementById('v-tagline').value.trim(),
    what_they_supply: document.getElementById('v-supply').value.trim(),
    story: document.getElementById('v-story').value.trim(),
    website_url: document.getElementById('v-website').value.trim(),
    logo_url: document.getElementById('v-logo').value.trim(),
    country: document.getElementById('v-country').value.trim(),
    category: document.getElementById('v-category').value,
    featured: document.getElementById('v-featured').checked,
    active: true
  };
  const url = editingVendorId ? '/api/admin/vendors/' + editingVendorId : '/api/admin/vendors';
  const method = editingVendorId ? 'PUT' : 'POST';
  const res = await fetch(url, { method, credentials: 'include', headers: {'Content-Type':'application/json'}, body: JSON.stringify(data) });
  if (res.ok) { closeVendorModal(); loadVendors(); }
  else { alert('Error saving vendor'); }
}

async function editVendor(id) {
  const res = await fetch('/api/vendors');
  const vendors = await res.json();
  const v = vendors.find(v => v.id === id);
  if (v) openVendorModal(v);
}

async function deleteVendor(id, name) {
  if (!confirm('Delete ' + name + '?')) return;
  const res = await fetch('/api/admin/vendors/' + id, { method: 'DELETE', credentials: 'include' });
  if (res.ok) loadVendors();
}
</script>

<div id="vendor-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.8);z-index:1000;overflow-y:auto;padding:20px">
  <div style="background:#1a0e10;border:1px solid #8b7355;border-radius:8px;max-width:500px;margin:0 auto;padding:24px">
    <h3 id="v-modal-title" style="color:#d4af7a;margin:0 0 20px">Add Vendor</h3>
    <label class="form-label">NAME *</label>
    <input class="form-input" id="v-name" placeholder="e.g. DeCheeso">
    <label class="form-label" style="margin-top:10px">TAGLINE</label>
    <input class="form-input" id="v-tagline" placeholder="e.g. Authentic Italian Cheese">
    <label class="form-label" style="margin-top:10px">WHAT THEY SUPPLY</label>
    <input class="form-input" id="v-supply" placeholder="e.g. Imported cheese for our sauces">
    <label class="form-label" style="margin-top:10px">STORY (shown to customers)</label>
    <textarea class="form-input" id="v-story" rows="3" placeholder="Tell their story..."></textarea>
    <label class="form-label" style="margin-top:10px">WEBSITE URL</label>
    <input class="form-input" id="v-website" placeholder="https://example.com">
    <label class="form-label" style="margin-top:10px">LOGO URL (optional)</label>
    <input class="form-input" id="v-logo" placeholder="https://example.com/logo.png">
    <label class="form-label" style="margin-top:10px">COUNTRY / ORIGIN</label>
    <input class="form-input" id="v-country" placeholder="e.g. Italy, USA, Local">
    <label class="form-label" style="margin-top:10px">CATEGORY</label>
    <select class="form-input" id="v-category">
      <option value="cheese">Cheese</option>
      <option value="meat">Meat</option>
      <option value="produce">Produce</option>
      <option value="beverage">Beverage</option>
      <option value="dairy">Dairy</option>
      <option value="bread">Bread</option>
      <option value="seafood">Seafood</option>
      <option value="other">Other</option>
    </select>
    <label style="display:flex;align-items:center;gap:8px;margin-top:12px;font-size:12px;color:#8a7a6a;cursor:pointer">
      <input type="checkbox" id="v-featured"> Featured vendor
    </label>
    <div style="display:flex;gap:10px;margin-top:20px">
      <button onclick="saveVendor()" style="flex:1;background:var(--gold);color:var(--bg);border:none;padding:12px;font-family:Josefin Sans,sans-serif;font-size:11px;letter-spacing:1.5px;cursor:pointer;border-radius:4px">Save</button>
      <button onclick="closeVendorModal()" style="flex:1;background:transparent;border:1px solid #3a2a1a;color:#8a7a6a;padding:12px;cursor:pointer;border-radius:4px">Cancel</button>
    </div>
  </div>
</div>
</body>
</html>
